              "raw": "http://{{base_url}}/notes/{{user_a_note_id}}",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["notes", "{{user_a_note_id}}"]
            }
          }
        },
        {
          "name": "Delete Note (User A)",
          "description": "Elimina la nota del usuario A",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Message says deleted', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.message).to.include('deleted');",
                  "});",
                  "",
                  "pm.test('Verify deleted - should return 404', function (done) {",
                  "  pm.sendRequest({",
                  "    url: pm.collectionVariables.get('base_url') ? 'http://' + pm.collectionVariables.get('base_url') + '/notes/' + pm.collectionVariables.get('user_a_note_id') : 'http://localhost:3000/notes/' + pm.collectionVariables.get('user_a_note_id'),",
                  "    method: 'GET',",
                  "    header: {",
                  "      'Authorization': 'Bearer ' + pm.collectionVariables.get('user_a_token')",
                  "    }",
                  "  }, function (err, res) {",
                  "    pm.expect(res.code).to.eql(404);",
                  "    done();",
                  "  });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{user_a_token}}" }
            ],
            "url": {
              "raw": "http://{{base_url}}/notes/{{user_a_note_id}}",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["notes", "{{user_a_note_id}}"]
            }
          }
        }
