        {
          "name": "Get Profile",
          "description": "Obtiene el perfil del usuario autenticado (requiere Access Token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has id, email, createdAt', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.all.keys('id', 'email', 'createdAt');",
                  "  pm.expect(json.email).to.eql(pm.collectionVariables.get('user_a_email'));",
                  "});",
                  "",
                  "pm.test('Password not exposed', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.not.have.property('password');",
                  "});"
                ]
              }
            }
