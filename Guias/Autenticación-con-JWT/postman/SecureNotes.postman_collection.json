        {
          "name": "Refresh Token",
          "description": "Refresca el access token usando el refresh token (cookie httpOnly). Nota: en Postman debes tener la cookie refresh_token configurada.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('New accessToken returned', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('accessToken');",
                  "  pm.expect(json.accessToken).to.be.a('string');",
                  "  pm.collectionVariables.set('access_token', json.accessToken);",
                  "});"
                ]
              }
            }
          ],
