            "url": {
              "raw": "http://{{base_url}}/auth/me",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            }
          }
        },
        {
          "name": "Get Sessions",
          "description": "Lista las sesiones activas del usuario autenticado",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Returns array of sessions', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.be.an('array');",
                  "  if (json.length > 0) {",
                  "    pm.expect(json[0]).to.have.all.keys('id', 'userAgent', 'createdAt', 'expiresAt');",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{user_a_token}}" }
            ],
            "url": {
              "raw": "http://{{base_url}}/auth/sessions",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["auth", "sessions"]
            }
          }
        },
        {
          "name": "Logout",
          "description": "Cierra la sesion actual, revoca el refresh token y limpia la cookie",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Message says logged out', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.message).to.include('Logged out');",
                  "});",
                  "",
                  "pm.test('refresh_token cookie cleared', function () {",
                  "  const cookies = pm.response.headers.filter(h => h.key.toLowerCase() === 'set-cookie');",
                  "  const hasClear = cookies.some(h => h.value.includes('refresh_token=;') || h.value.includes('refresh_token=\"\"'));",
                  "  pm.expect(hasClear).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{user_a_token}}" }
            ],
            "url": {
              "raw": "http://{{base_url}}/auth/logout",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            }
          }
        }
      ]
    },
