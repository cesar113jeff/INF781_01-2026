    {
      "name": "Auth",
      "description": "Endpoints de autenticacion: registro, login, refresh, logout, perfil, sesiones",
      "item": [
        {
          "name": "Register User A",
          "description": "Registra el usuario A en el sistema",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has id, email, accessToken', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.all.keys('id', 'email', 'accessToken');",
                  "  pm.expect(json.email).to.eql(pm.collectionVariables.get('user_a_email'));",
                  "});",
                  "",
                  "pm.test('accessToken saved', function () {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('user_a_token', json.accessToken);",
                  "  pm.expect(json.accessToken).to.be.a('string');",
                  "});",
                  "",
                  "pm.test('refresh_token cookie set', function () {",
                  "  const cookies = pm.response.headers.filter(h => h.key.toLowerCase() === 'set-cookie');",
                  "  const hasRefresh = cookies.some(h => h.value.includes('refresh_token'));",
                  "  pm.expect(hasRefresh).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_a_email}}\",\n  \"password\": \"{{user_a_password}}\"\n}"
            },
            "url": {
              "raw": "http://{{base_url}}/auth/register",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
