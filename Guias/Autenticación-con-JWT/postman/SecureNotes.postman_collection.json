    {
      "name": "Security Tests",
      "description": "Pruebas de seguridad: anti-IDOR, autenticacion, autorizacion, reuse detection",
      "item": [
        {
          "name": "TEST: Access without token",
          "description": "Intenta acceder a /notes sin token. Debe retornar 401.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401 - Unauthorized', function () {",
                  "  pm.response.to.have.status(401);",
                  "});",
                  "",
                  "pm.test('Error message present', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('message');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://{{base_url}}/notes",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["notes"]
            }
          }
        },
        {
          "name": "TEST: Access with invalid token",
          "description": "Intenta acceder con un token JWT invalido. Debe retornar 401.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401 - Unauthorized', function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer invalid.token.here" }
            ],
            "url": {
              "raw": "http://{{base_url}}/notes",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["notes"]
            }
          }
        },
        {
          "name": "TEST: Anti-IDOR - User B cannot read User A note",
          "description": "User B intenta acceder a una nota de User A por ID. Debe retornar 404 (nunca 403).",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 - Not Found (anti-IDOR)', function () {",
                  "  pm.response.to.have.status(404);",
                  "});",
                  "",
                  "pm.test('NOT 403 Forbidden', function () {",
                  "  pm.expect(pm.response.code).to.not.eql(403);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{user_b_token}}" }
            ],
            "url": {
              "raw": "http://{{base_url}}/notes/{{user_a_note_id}}",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["notes", "{{user_a_note_id}}"]
            }
          }
        },
        {
          "name": "TEST: Anti-IDOR - User B cannot update User A note",
          "description": "User B intenta actualizar una nota de User A. Debe retornar 404.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 - Not Found (anti-IDOR)', function () {",
                  "  pm.response.to.have.status(404);",
                  "});",
                  "",
                  "pm.test('NOT 403 Forbidden', function () {",
                  "  pm.expect(pm.response.code).to.not.eql(403);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_b_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"HACKED\"\n}"
            },
            "url": {
              "raw": "http://{{base_url}}/notes/{{user_a_note_id}}",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["notes", "{{user_a_note_id}}"]
            }
          }
